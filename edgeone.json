{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": "./dist",
  "nodeVersion": "20.18.0",
  "redirects": [
    {
      "source": "/api",
      "destination": "/api.js",
      "statusCode": 302
    }
  ],
  "headers": [
    {
      "source": "/*",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Cache-Control",
          "value": "max-age=7200"
        }
      ]
    },
    {
      "source": "/converted/*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "max-age=31536000"
        }
      ]
    }
  ],
  "caches": [
    {
      "source": "/converted/*",
      "cacheTtl": 86400
    }
  ]
}